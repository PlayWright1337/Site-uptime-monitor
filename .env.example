# ===================================
#   SITE UPTIME MONITOR — .env
# ===================================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin IDs — administrators who can configure the bot
# Multiple IDs separated by commas
ADMIN_IDS=123456789,987654321

# User IDs — users who receive notifications (optional)
# Multiple IDs separated by commas
USER_IDS=111111111,222222222

# Group IDs — groups/channels that receive notifications (optional)
# Use negative IDs for groups, e.g. -1001234567890
# Can be empty — the bot will NOT crash if this is empty
GROUP_IDS=
